<idea-plugin>
    <id>com.caro.nbascore</id>
    <name>NBA Live Score</name>
    <vendor email="creaternuri@gmail.com">Caro</vendor>
    <description>
        Live Score Plugin - View NBA game live scores in IDEA
        <![CDATA[
        <p>NBA 实时比分插件 - 在 IDEA 中查看 NBA 比赛实时比分</p>
        <ul>
            <li>实时显示当天 NBA 比赛比分</li>
            <li>支持自动刷新</li>
            <li>点击查看详细比赛数据</li>
            <li>工具栏快捷访问</li>
        </ul>
        ]]>
    </description>
    <depends>com.intellij.modules.platform</depends>
    
    <!-- 兼容 IDEA 2024.2 (build 242) 到 2025.3+ -->
    <idea-version since-build="242"/>
    
    <actions>
        <group id="NBA.Score.Toolbar" text="NBA Score" description="NBA Live Score">
            <add-to-group group-id="MainToolBar" anchor="last"/>
            <action id="NBA.Refresh" class="com.caro.nba.RefreshAction" text="刷新比分" icon="/icons/nba.svg"/>
        </group>
    </actions>
    
    <extensions defaultExtensionNs="com.intellij">
        <toolWindow id="NBA Score" 
                    factoryClass="com.caro.nba.NBAScoreToolWindowFactory"
                    anchor="right" 
                    icon="/icons/nba.svg"/>
        
        <!-- AI 助手设置 -->
        <applicationService serviceImplementation="com.caro.nba.NBASettingsState"/>
        <applicationConfigurable parentId="tools" 
                                 instance="com.caro.nba.NBASettingsConfigurable" 
                                 id="com.caro.nba.settings"
                                 displayName="NBA AI 助手"/>
    </extensions>

    <change-notes><![CDATA[
        <h3>4.0.0</h3>
        <ul>
            <li>新增：AI 数据问答助手（支持自定义 API）</li>
            <li>新增：标签页布局（比分/排名/季后赛/AI助手）</li>
            <li>新增：API 限流（1分钟5次）</li>
        </ul>
        <h3>3.0.9</h3>
        <ul>
            <li>恢复：还原原始插件图标</li>
        </ul>
        <h3>3.0.8</h3>
        <ul>
            <li>修复：西部球队季后赛锁定标记不显示的问题（支持 '*' 标记）</li>
        </ul>
        <h3>3.0.7</h3>
        <ul>
            <li>优化：季后赛锁定标记简化为 ✓（去掉赛区/联盟第1文字）</li>
        </ul>
        <h3>3.0.6</h3>
        <ul>
            <li>修复：季后赛锁定标记文字更清晰（赛区第1/联盟第1/已锁定）</li>
        </ul>
        <h3>3.0.5</h3>
        <ul>
            <li>新增：排名表格显示季后赛锁定标记（✓ 分区冠军/联盟冠军/已锁定）</li>
            <li>优化：季后赛对阵图西部布局镜像对称（决赛朝向总决赛中心）</li>
        </ul>
        <h3>3.0.4</h3>
        <ul>
            <li>更新：全新的插件图标设计（篮球+比分板风格）</li>
            <li>优化：更现代的视觉风格</li>
        </ul>
        <h3>3.0.3</h3>
        <ul>
            <li>修复：兼容 IDEA 2025.3+ 版本 (build 253+)</li>
            <li>优化：移除冗余的 coroutines 依赖</li>
        </ul>
    ]]></change-notes>

</idea-plugin>